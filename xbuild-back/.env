# ── XBuild Backend — fichier .env ────────────────────────────────────────────

# ── MongoDB connection string ─────────────────────────────────────────────────
# Local:        mongodb://localhost:27017/xbuild
# Atlas:        mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/xbuild
MONGODB_URI=mongodb://localhost:27017/xbuild

# Mot de passe de l'interface d'administration
ADMIN_PASSWORD=xbuild2024

# Clé secrète pour signer les tokens JWT (changez-la en production !)
JWT_SECRET=xbuild_jwt_secret_change_me_in_production

# Port d'écoute du serveur Express (par défaut : 5174)
PORT=5174